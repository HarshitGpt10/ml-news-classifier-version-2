# ─── Copy this file to .env and fill in your values ───────────────────────────
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/mlnews

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Model paths ───────────────────────────────────────────────────────────────
BASELINE_MODEL_PATH=ml_pipeline/models/baseline/tfidf_lr_pipeline.joblib
LSTM_MODEL_PATH=ml_pipeline/models/lstm/lstm_best.pt
DISTILBERT_MODEL_PATH=ml_pipeline/models/distilbert/best_model

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_MODEL_NAME=distilbert-base-uncased

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
